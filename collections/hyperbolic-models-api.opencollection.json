{
  "opencollection": "1.0.0",
  "info": {
    "name": "Hyperbolic Models API",
    "version": "v1"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Models",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Hyperbolic List Models",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.hyperbolic.xyz/v1/models"
          },
          "docs": "List all models currently available for inference."
        }
      ]
    }
  ],
  "bundled": true
}