          },
          "http": {
            "method": "POST",
            "url": "https://api.hyperbolic.xyz/v1/completions",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Generate a text completion for a prompt against a base (non-instruct) model. Primarily used for the Llama-3.1-405B-Base BF16 and FP8 variants unique to Hyperbolic.\n"
        }
      ]
    }
  ],
  "bundled": true
}